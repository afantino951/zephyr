#include <mem.h>

/ {
	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		/* CPU0 */
		sram0_cpu0: memory@20000000 {
			reg = <0x20000000 DT_SIZE_K(128)>;
		};

		// cpu1_slot0_partition: memory@20020000 {
		// 	reg = <0x20020000 DT_SIZE_K(128)>;
		// };

		/* CPU1 */
		sram0_cpu1: memory@20040000 {
			reg = <0x20040000 DT_SIZE_K(256)>;
		};

		/* Shared and directly mapped */
		sram8: memory@20080000 {
			reg = <0x20080000 DT_SIZE_K(4)>;
		};
		sram9: memory@20081000 {
			reg = <0x20081000 DT_SIZE_K(4)>;
		};
	};

	/*
	* Not sure if this is what you meant, but I can still flash with west flash
	* like this.
	*/
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		slot0_partition: partition@10000000 {
			label = "image-0";
			reg = <0x10000000 DT_SIZE_M(2)>;
		};

		cpu1_slot0_partition: partition@10200000 {
			label = "cpu1-image";
			reg = <0x10200000 DT_SIZE_K(256)>;
		};

		storage_partition: partition@10240000 {
			label = "storage";
			reg = <0x10240000 DT_SIZE_K(1792)>;
		};
	};
};
