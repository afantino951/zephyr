&ipm0 {
	ipm_mbox: ipm-mbox {
		compatible = "zephyr,ipm-mbox";
		#mbox-cells = <1>;
		channels = <2>;
		status = "okay";
	};
};

/ {
	ipc {
		ipc0: ipc0 {
			compatible = "zephyr,ipc-icmsg";
			tx-region = <&sram8>;
			rx-region = <&sram9>;
			dcache-alignment = <32>;
			mboxes = <&ipm_mbox 0>, <&ipm_mbox 1>;
			mbox-names = "tx", "rx";
			status = "okay";
		};
	};
};
